# Supabase Database
# Get this from: https://app.supabase.com/project/_/settings/database
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxxx.supabase.co:5432/postgres"

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-change-this

# Thumbtack OAuth
THUMBTACK_CLIENT_ID=your-thumbtack-client-id
THUMBTACK_CLIENT_SECRET=your-thumbtack-client-secret
THUMBTACK_REDIRECT_URI=http://localhost:3000/v1/thumbtack/auth/callback
THUMBTACK_WEBHOOK_SECRET=your-thumbtack-webhook-secret

# Callio SMS Integration
# Webhook secret for verifying delivery status callbacks
CALLIO_WEBHOOK_SECRET=your-callio-webhook-secret

# Yelp (for future use)
YELP_API_KEY=your-yelp-api-key
YELP_CLIENT_ID=your-yelp-client-id
YELP_CLIENT_SECRET=your-yelp-client-secret
YELP_WEBHOOK_SECRET=your-yelp-webhook-secret

# Optional: Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=info
