VITE_API_URL=https://leadbridge-production.up.railway.app/api

# Firebase Analytics (GA4 via Firebase)
# Leave these unset in dev to no-op analytics. Fill for staging/prod.
# Create at https://console.firebase.google.com → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
