    "@nestjs/schematics": "^11.0.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
