{
  "name": "thumbtack-bridge",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "build": "npm run build:frontend && prisma generate && tsc",
    "build:frontend": "cd frontend && npm install --include=dev && npm run build",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "thumbtack",
    "api",
    "bridge",
    "integration",
    "leads",
    "crm"
  ],
  "author": "",
  "license": "MIT",
  "description": "Multi-platform lead integration service for Thumbtack, Yelp, and other platforms",
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/client": "^6.19.1",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "stripe": "^20.3.0"
