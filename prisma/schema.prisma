// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// Enums for Billing & Admin
// ==========================================

enum UserRole {
  USER
  ADMIN
}

// ==========================================
// Enums for Instant Call Connect
// ==========================================

enum CallConnectMode {
  AGENT_FIRST
  PARALLEL
}

enum CallConnectStatus {
  CREATED
  CALLING_AGENT
  AGENT_ANSWERED
  AGENT_ACCEPTED
  CALLING_LEAD
  BRIDGED
  VOICEMAIL_DROP
  ENDED
  FAILED
  CANCELED
  // legacy values kept for backward compat with existing rows
  RINGING_AGENT
  RINGING_LEAD
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

// ==========================================
// Core User Management
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?  // For user authentication in your app
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role & Subscription fields
  role                  UserRole            @default(USER)
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  subscriptionTier      SubscriptionTier?
  subscriptionStatus    SubscriptionStatus?
  subscriptionPeriodEnd DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)
  hasOwnNumber          Boolean             @default(false)

  // Trial period
  trialStartDate        DateTime?
  trialEndDate          DateTime?
  trialUsed             Boolean             @default(false)
  trialLeadsHandled     Int                 @default(0)
  trialLeadsLimit       Int                 @default(10)

  // Track Thumbtack account to prevent trial abuse
  // Users can't get another trial with same Thumbtack account
  thumbtackBusinessId   String?
  thumbtackAccountEmail String?

  // Sigcore phone number provisioning
  phoneNumber           String?  // User's dedicated Sigcore/Twilio number
  sigcoreAllocationId   String?  @map("callioAllocationId") // Sigcore's allocation ID for this number

  // Password reset
  passwordResetToken    String?
  passwordResetExpires  DateTime?

  // Relationships
  platforms                Platform[]
  leads                    Lead[]
  conversations            Conversation[]
  messages                 Message[]
  savedAccounts            SavedAccount[]
  messageTemplates         MessageTemplate[]
  automationRules          AutomationRule[]
  subscriptionHistory      SubscriptionHistory[]
  adminLogs                AdminLog[]
  notificationSettings     NotificationSettings[] // Account-specific and user-level default notification settings
  poolPhones               PhonePool[]            // Legacy: single-assignment relation
  phonePoolAssignments     PhonePoolAssignment[]  // Many-to-many phone pool assignments
  thumbtackSnapshots       ThumbtackSettingsSnapshot[]
  thumbtackLeadIds         ThumbtackLeadId[]
  callConnectSettings      CallConnectSettings[]

  @@map("users")
}

// ==========================================
// Multi-Platform Integration
// ==========================================

model Platform {
  id                 String   @id @default(uuid())
  userId             String
  platformName       String   // "thumbtack" | "yelp" | "angi" | "bark"
  connected          Boolean  @default(true)
  externalUserId     String?  // Platform's user ID
  externalBusinessId String?  // Platform's business ID (for webhook matching)
  credentialsJson    String   // Encrypted: access_token, refresh_token, api_key, etc.
  webhookSecret      String?  // Encrypted webhook verification secret
  webhookId          String?  // Platform's webhook subscription ID
  lastSyncAt         DateTime?
  metadataJson       String?  // Additional platform-specific data
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformName])
  @@index([userId])
  @@index([platformName])
  @@index([externalBusinessId])
  @@map("platforms")
}

// ==========================================
// Normalized Lead Management
// ==========================================

model Lead {
  id                String   @id @default(uuid())
  userId            String
  platform          String   // "thumbtack" | "yelp" | etc.
  businessId        String?  // Platform's business ID (for multi-account filtering)
  externalRequestId String   // Platform's unique lead/request ID
  customerName      String
  customerPhone     String?
  customerEmail     String?
  message           String   @db.Text
  budget            Decimal? @db.Decimal(10, 2)
  postcode          String?
  city              String?
  state             String?
  category          String?  // Service category
  status            String   @default("new") // "new" | "contacted" | "quoted" | "booked" | "lost"
  thumbtackStatus   String?  // Job status from Thumbtack UI (e.g. "Hired", "Not hired")
  threadId          String?  // Universal conversation ID
  rawJson           String   @db.Text // Original platform payload
  syncedToCrm       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user                    User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation            Conversation?                 @relation(fields: [threadId], references: [id])
  pendingMessages         PendingAutomatedMessage[]
  pendingNotificationMsgs PendingNotificationMessage[]
  callConnectSessions     LeadCallConnect[]

  @@unique([platform, externalRequestId])
  @@index([userId])
  @@index([platform])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// ==========================================
// Messaging & Conversations
// ==========================================

model Conversation {
  id              String   @id @default(uuid())
  userId          String
  platform        String   // "thumbtack" | "yelp" | etc.
  externalThreadId String  // Platform's conversation/thread ID
  customerName    String
  lastMessageAt   DateTime @default(now())
  unreadCount     Int      @default(0)
  status          String   @default("active") // "active" | "archived" | "closed"
  metadataJson    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  leads    Lead[]

  @@unique([platform, externalThreadId])
  @@index([userId])
  @@index([platform])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String
  userId          String
  platform        String   // "thumbtack" | "yelp" | etc.
  externalMessageId String? // Platform's message ID
  sender          String   // "pro" | "customer" | "system"
  content         String   @db.Text
  isRead          Boolean  @default(false)
  sentAt          DateTime @default(now())
  deliveredAt     DateTime?
  rawJson         String?  @db.Text
  createdAt       DateTime @default(now())

  // Relationships
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, externalMessageId])
  @@index([conversationId])
  @@index([userId])
  @@index([sentAt])
  @@map("messages")
}

// ==========================================
// Quote & Negotiation Tracking
// ==========================================

model Quote {
  id              String   @id @default(uuid())
  userId          String
  platform        String
  externalQuoteId String?  // Platform's quote ID
  leadId          String?  // Reference to lead if applicable
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  description     String?  @db.Text
  status          String   @default("pending") // "pending" | "accepted" | "rejected" | "expired"
  validUntil      DateTime?
  rawJson         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("quotes")
}

// ==========================================
// Message Templates (for bulk follow-up messages)
// ==========================================

model MessageTemplate {
  id          String    @id @default(uuid())
  userId      String
  name        String    // Template name for identification
  content     String    @db.Text // Template content with {variables}
  isDefault   Boolean   @default(false)
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRules   AutomationRule[]
  notificationRules NotificationRule[]

  @@index([userId])
  @@map("message_templates")
}

// ==========================================
// Saved Accounts (for multi-account switching)
// ==========================================

model SavedAccount {
  id              String   @id @default(uuid())
  userId          String
  platform        String   // "thumbtack"
  businessId      String   // Platform's business ID
  businessName    String   // Display name
  emailHint       String?  // Email used for this account (optional hint)
  imageUrl        String?  // Business logo URL
  webhookId       String?  // Webhook subscription ID for this business
  credentialsJson String?  // Encrypted: access_token, refresh_token for THIS account
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  // Relationships
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRules      AutomationRule[]
  notificationSettings NotificationSettings?
  callConnectSettings  CallConnectSettings?
  collectedLeads       ThumbtackLeadId[]
  settingsSnapshots    ThumbtackSettingsSnapshot[]

  @@unique([userId, platform, businessId])
  @@index([userId])
  @@map("saved_accounts")
}

// ==========================================
// Webhook Event Log
// ==========================================

model WebhookEvent {
  id           String   @id @default(uuid())
  platform     String
  eventType    String   // "request.created" | "message.created" | etc.
  payload      String   @db.Text
  signature    String?
  verified     Boolean  @default(false)
  processed    Boolean  @default(false)
  processingError String? @db.Text
  receivedAt   DateTime @default(now())
  processedAt  DateTime?

  @@index([platform])
  @@index([eventType])
  @@index([processed])
  @@index([receivedAt])
  @@map("webhook_events")
}

// ==========================================
// Automation Rules (for auto-sending messages)
// ==========================================

model AutomationRule {
  id               String    @id @default(uuid())
  savedAccountId   String    // Per-account rules
  userId           String
  name             String    // User-friendly rule name
  triggerType      String    // "new_lead" | "customer_reply"
  replyTriggerMode String?   // For customer_reply: "first_only" | "every_reply"
  templateId       String    // Reference to MessageTemplate
  delayMinutes     Int       @default(0) // Delay before sending (0 = immediate)
  enabled          Boolean   @default(true)
  triggerCount     Int       @default(0)
  lastTriggeredAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  savedAccount    SavedAccount              @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        MessageTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pendingMessages PendingAutomatedMessage[]

  @@index([savedAccountId])
  @@index([userId])
  @@index([triggerType])
  @@index([enabled])
  @@map("automation_rules")
}

model PendingAutomatedMessage {
  id               String    @id @default(uuid())
  automationRuleId String
  leadId           String
  negotiationId    String    // External negotiation ID (for dedup)
  scheduledFor     DateTime  // When to send
  status           String    @default("pending") // "pending" | "sent" | "cancelled" | "failed"
  failureReason    String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  // Relationships
  automationRule AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([automationRuleId, negotiationId])
  @@index([status])
  @@index([scheduledFor])
  @@map("pending_automated_messages")
}

// ==========================================
// SMS Notification Settings (Sigcore Integration)
// ==========================================

model NotificationSettings {
  id                String   @id @default(uuid())
  savedAccountId    String?  @unique // Per-account settings (optional - if null, this is user-level default)
  userId            String?  // User ID (for account-specific AND user-level settings)
  enabled           Boolean  @default(false)
  destinationPhone  String?  // Company phone to send notifications to
  senderMode        String   @default("shared") // "shared" | "dedicated" | "openphone"
  sigcoreApiKey      String?  @map("callioApiKey") // Encrypted Sigcore API key
  sigcoreFromPhone   String?  @map("callioFromPhone") // Selected phone number from Sigcore to send from
  sigcoreWorkspaceId String?  @map("callioWorkspaceId") // Sigcore workspace ID for this tenant
  sigcoreWebhookId   String?  @map("callioWebhookId") // Sigcore webhook ID for delivery status updates
  sigcoreProvider    String?  // Connected provider: "openphone" | "twilio"
  template          String   @db.Text @default("New lead: {{lead.name}}\nPhone: {{lead.phone}}\nService: {{lead.service}}\nLocation: {{lead.location}}")
  quietHoursStart   String?  // e.g., "22:00"
  quietHoursEnd     String?  // e.g., "08:00"
  quietHoursTimezone String? @default("America/New_York")
  requirePhone      Boolean  @default(true) // Only notify if lead has phone
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user              User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAccount      SavedAccount?       @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  notificationLogs  NotificationLog[]
  notificationRules NotificationRule[]

  @@index([savedAccountId])
  @@index([userId])
  @@map("notification_settings")
}

// ==========================================
// SMS Notification Rules
// ==========================================

model NotificationRule {
  id                     String   @id @default(uuid())
  notificationSettingsId String   // Link to parent settings
  name                   String   // User-friendly rule name (e.g., "New Lead Alert")
  triggerType            String   // "new_lead" | "customer_reply"
  replyTriggerMode       String?  // For customer_reply: "first_only" | "every_reply"
  fromPhone              String?  // Sigcore phone number to send FROM
  toPhone                String?  // Destination phone number to send TO
  sendToCustomer         Boolean  @default(false) // If true, send SMS to lead.customerPhone instead of toPhone
  template               String   @db.Text // SMS template for this specific rule (fallback if no templateId)
  templateId             String?  // Optional link to MessageTemplate
  delayMinutes           Int      @default(0) // Delay before sending (0 = immediate)
  stopOnCustomerReply    Boolean  @default(true) // Cancel pending follow-ups if customer replies
  stopOnLeadClosed       Boolean  @default(true) // Cancel pending follow-ups if lead closed/won/lost
  stopOnOptOut           Boolean  @default(true) // Cancel pending follow-ups if customer sends STOP
  enabled                Boolean  @default(true)
  triggerCount           Int      @default(0)
  lastTriggeredAt        DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relationships
  notificationSettings NotificationSettings @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  messageTemplate      MessageTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  notificationLogs     NotificationLog[]
  pendingMessages      PendingNotificationMessage[]

  @@index([notificationSettingsId])
  @@index([triggerType])
  @@index([enabled])
  @@map("notification_rules")
}

model PendingNotificationMessage {
  id                   String    @id @default(uuid())
  notificationRuleId   String
  leadId               String
  savedAccountId       String    // For quick lookups by account
  scheduledFor         DateTime  // When to send
  status               String    @default("pending") // "pending" | "sent" | "cancelled" | "failed"
  failureReason        String?
  sentAt               DateTime?
  createdAt            DateTime  @default(now())

  // Relationships
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
  lead             Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([notificationRuleId, leadId])
  @@index([status])
  @@index([scheduledFor])
  @@index([savedAccountId])
  @@map("pending_notification_messages")
}

model NotificationLog {
  id                    String    @id @default(uuid())
  notificationSettingsId String
  notificationRuleId    String?   // Reference to the rule that triggered this
  ruleName              String?   // Cached rule name for display
  leadId                String?   // Reference to the lead that triggered this
  toPhone               String    // Destination phone number
  fromPhone             String?   // Sender phone number
  provider              String?   // "twilio" | "openphone" | etc.
  sigcoreMessageId       String?   @map("callioMessageId") // Sigcore's message ID
  sigcoreConversationId  String?   @map("callioConversationId") // Sigcore's conversation ID
  status                String    @default("pending") // "pending" | "queued" | "sent" | "delivered" | "failed"
  error                 String?   @db.Text
  messageBody           String    @db.Text // Rendered message content
  metadata              String?   @db.Text // JSON metadata
  createdAt             DateTime  @default(now())
  sentAt                DateTime?
  deliveredAt           DateTime?

  // Relationships
  notificationSettings NotificationSettings @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  notificationRule     NotificationRule?    @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)

  @@index([notificationSettingsId])
  @@index([notificationRuleId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

// ==========================================
// Subscription & Billing Tracking
// ==========================================

model SubscriptionHistory {
  id            String             @id @default(uuid())
  userId        String
  tier          SubscriptionTier
  status        SubscriptionStatus
  eventType     String // "subscription.created", "subscription.updated", etc.
  stripeEventId String             @unique
  metadata      Json? // Store full Stripe event data
  createdAt     DateTime           @default(now())

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("subscription_history")
}

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String // "UPDATE_USER_SUBSCRIPTION", "DELETE_USER", etc.
  targetUserId String?
  details      Json?
  createdAt    DateTime @default(now())

  // Relationships
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}

// ==========================================
// Admin Phone Pool
// ==========================================

enum PhonePoolStatus {
  AVAILABLE
  ASSIGNED
  RESERVED
  RELEASED
}

model PhonePool {
  id                  String          @id @default(uuid())
  phoneNumber         String          @unique
  provider            String          @default("twilio") // "twilio" | "openphone"
  areaCode            String?
  state               String?         // US state abbreviation
  friendlyName        String?
  sigcoreAllocationId String?
  status              PhonePoolStatus @default(AVAILABLE)
  assignedToUserId    String?         // Legacy: kept for backward compat
  assignedAt          DateTime?       // Legacy: kept for backward compat
  provisionedAt       DateTime        @default(now())
  releasedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relationships
  assignedToUser User?               @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  assignments    PhonePoolAssignment[] // Many-to-many assignments

  @@index([status])
  @@index([areaCode])
  @@index([assignedToUserId])
  @@map("phone_pool")
}

model PhonePoolAssignment {
  id          String   @id @default(uuid())
  phonePoolId String
  userId      String
  assignedAt  DateTime @default(now())

  phonePool PhonePool @relation(fields: [phonePoolId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([phonePoolId, userId])
  @@index([userId])
  @@index([phonePoolId])
  @@map("phone_pool_assignments")
}

// ==========================================
// Thumbtack Chrome Extension Integration
// ==========================================

model ThumbtackSettingsSnapshot {
  id             String    @id @default(uuid())
  userId         String
  savedAccountId String?
  provider       String    @default("thumbtack")
  snapshotType   String    @default("budget")
  scopeCategory  String?
  scopeLocation  String?
  weeklyBudget   Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  capturedAt     DateTime
  receivedAt     DateTime  @default(now())
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  source         String?
  pageUrl        String?
  pageTitle      String?
  rawJson        Json?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAccount SavedAccount? @relation(fields: [savedAccountId], references: [id])

  @@index([userId, snapshotType, effectiveFrom])
  @@index([userId, snapshotType, effectiveTo])
  @@index([userId, scopeCategory, scopeLocation, effectiveFrom])
  @@index([savedAccountId])
  @@map("thumbtack_settings_snapshots")
}

// ==========================================
// Instant Call Connect
// ==========================================

model CallConnectSettings {
  id                   String          @id @default(uuid())
  savedAccountId       String          @unique
  userId               String
  enabled              Boolean         @default(false)
  mode                 CallConnectMode @default(AGENT_FIRST)
  agentStrategy        String          @default("owner") // "owner" | "round_robin" | "on_duty"
  agentPhoneE164       String?         // Agent's phone number to ring
  botNumberE164        String?         // Shared bot caller-ID number
  sigcoreWebhookSecret String?         // HMAC secret registered with Sigcore webhook subscription
  sigcoreWebhookId     String?         // Sigcore webhook subscription ID (for dedup)
  maxAgentAttempts     Int             @default(2)
  quietHoursEnabled    Boolean         @default(false)
  quietHoursTimezone   String?
  quietHoursStart      String?         // "HH:MM"
  quietHoursEnd        String?         // "HH:MM"
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  savedAccount SavedAccount @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("call_connect_settings")
}

model LeadCallConnect {
  id               String            @id @default(uuid())
  leadId           String
  businessId       String?           // Sigcore workspace/business ID (stored for reference)
  sigcoreSessionId String            @unique
  status           CallConnectStatus @default(CREATED)
  attempt          Int               @default(0)
  lastEventAt      DateTime          @default(now())
  failureReason    String?
  recordingUrl     String?
  timeline         Json              @default("[]") // Append-only array of event objects
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([sigcoreSessionId])
  @@map("lead_call_connect")
}

model ThumbtackLeadId {
  id              String    @id @default(uuid())
  userId          String
  savedAccountId  String?
  thumbtackId     String
  batchId         String?
  capturedAt      DateTime
  collectedAt     DateTime  @default(now())
  source          String?
  pageUrl         String?
  pageTitle       String?
  thumbtackStatus String?
  customerName    String?
  imported        Boolean   @default(false)
  importedAt      DateTime?
  needsRefetch    Boolean   @default(false)
  lastActivityAt  DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAccount SavedAccount? @relation(fields: [savedAccountId], references: [id])

  @@unique([userId, thumbtackId])
  @@index([userId, collectedAt(sort: Desc)])
  @@index([batchId])
  @@index([savedAccountId])
  @@map("thumbtack_lead_ids")
}
