// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  // relationJoins enables `relationLoadStrategy: 'join'` — opt-in per query.
  // Default strategy is unchanged; only queries that explicitly request 'join'
  // collapse multi-statement includes into a single SQL statement.
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// Enums for Billing & Admin
// ==========================================

enum UserRole {
  USER
  ADMIN
}

// ==========================================
// Enums for Instant Call Connect
// ==========================================

enum CallConnectMode {
  AGENT_FIRST
  PARALLEL
}

enum CallConnectStatus {
  CREATED
  CALLING_AGENT
  AGENT_ANSWERED
  AGENT_ACCEPTED
  CALLING_LEAD
  BRIDGED
  VOICEMAIL_DROP
  ENDED
  FAILED
  CANCELED
  // legacy values kept for backward compat with existing rows
  RINGING_AGENT
  RINGING_LEAD
  CANCELLED
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

enum TrialType {
  LEAD_BASED
  TIME_BASED
  HYBRID
}

// ==========================================
// Core User Management
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String? // For user authentication in your app
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role & Subscription fields
  role                  UserRole            @default(USER)
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  subscriptionTier      SubscriptionTier?
  subscriptionStatus    SubscriptionStatus?
  subscriptionPeriodEnd DateTime?
  cancelAtPeriodEnd     Boolean             @default(false)
  hasOwnNumber          Boolean             @default(false)

  // Trial period
  trialStartDate     DateTime?
  trialEndDate       DateTime?
  trialUsed          Boolean    @default(false)
  trialLeadsHandled  Int        @default(0)
  trialLeadsLimit    Int        @default(10)
  trialType          TrialType?
  trialEndedAt       DateTime?
  trialEndNotifiedAt DateTime?

  // Track Thumbtack account to prevent trial abuse
  // Users can't get another trial with same Thumbtack account
  thumbtackBusinessId   String?
  thumbtackAccountEmail String?

  // Business phone (agent's personal phone for receiving forwarded calls/SMS)
  businessPhone String?

  // Sigcore phone number provisioning
  phoneNumber         String? // User's dedicated Sigcore/Twilio number
  sigcoreAllocationId String? @map("callioAllocationId") // Sigcore's allocation ID for this number

  // Cross-app business identity (Sigcore registry references — transitional on User, will move to workspace+membership)
  sigcoreWorkspaceId String? @map("sigcore_workspace_id") // product_workspaces.id in Sigcore
  sigcoreBusinessId  String? @map("sigcore_business_id") // businesses.id in Sigcore

  // AI settings
  globalAiPrompt String? @map("global_ai_prompt") @db.Text // Global AI system prompt — applied to all AI replies

  // Password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // Relationships
  platforms                   Platform[]
  leads                       Lead[]
  conversations               Conversation[]
  messages                    Message[]
  savedAccounts               SavedAccount[]
  messageTemplates            MessageTemplate[]
  automationRules             AutomationRule[]
  subscriptionHistory         SubscriptionHistory[]
  adminLogs                   AdminLog[]
  notificationSettings        NotificationSettings[] // Account-specific and user-level default notification settings
  thumbtackSnapshots          ThumbtackSettingsSnapshot[]
  thumbtackLeadIds            ThumbtackLeadId[]
  callConnectSettings         CallConnectSettings[]
  tenantPhoneNumbers          TenantPhoneNumber[]
  conversationSyncConnections ConversationSyncConnection[]
  followUpSequenceTemplates   FollowUpSequenceTemplate[]
  orgMemberships              OrgMembership[]
  crmWebhookSubscriptions     CrmWebhookSubscription[]
  accountHealthStatuses       AccountHealthStatus[]
  onboardingProfile           OnboardingProfile?

  @@map("users")
}

// One-to-one profile capturing the answers from the post-signup qualification flow.
// Step 1 (required) collects lead source + volume + service type.
// Step 2 (optional) collects pain & value signals used for personalization.
model OnboardingProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Step 1 — required (blocking)
  primaryLeadSource    String? // "thumbtack" | "yelp" | "google" | "facebook" | "other"
  secondaryLeadSources String[]  @default([])
  weeklyLeadVolume     String? // "0-5" | "5-15" | "15-50" | "50+"
  serviceType          String? // "house_cleaning" | "carpet_upholstery" | "window_cleaning" | "pressure_washing" | "plumbing" | "electrical" | "hvac" | "handyman" | "landscaping" | "junk_removal" | "moving" | "pest_control" | "other"
  serviceTypeOther     String?
  step1CompletedAt     DateTime?
  step1SkippedAt       DateTime?

  // Step 2 — optional (skippable)
  responseSpeed     String? // "5min" | "30min" | "few_hours" | "later"
  missedLeadOutcome String? // "hire_someone_else" | "stop_replying" | "follow_up_later" | "not_sure"
  avgJobValue       String? // "under_100" | "100_200" | "200_500" | "500_plus"
  userGoal          String? // "respond_instantly" | "book_more" | "automate_follow_ups" | "notifications_only"
  step2CompletedAt  DateTime?
  step2SkippedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("onboarding_profiles")
}

// ==========================================
// Multi-Platform Integration
// ==========================================

model Platform {
  id                 String    @id @default(uuid())
  userId             String
  platformName       String // "thumbtack" | "yelp" | "angi" | "bark"
  connected          Boolean   @default(true)
  externalUserId     String? // Platform's user ID
  externalBusinessId String? // Platform's business ID (for webhook matching)
  credentialsJson    String // Encrypted: access_token, refresh_token, api_key, etc.
  webhookSecret      String? // Encrypted webhook verification secret
  webhookId          String? // Platform's webhook subscription ID
  lastSyncAt         DateTime?
  metadataJson       String? // Additional platform-specific data
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformName])
  @@index([userId])
  @@index([platformName])
  @@index([externalBusinessId])
  @@map("platforms")
}

// ==========================================
// Normalized Lead Management
// ==========================================

model Lead {
  id                     String    @id @default(uuid())
  userId                 String
  platform               String // "thumbtack" | "yelp" | etc.
  businessId             String? // Platform's business ID (for multi-account filtering)
  externalRequestId      String // Platform's unique lead/request ID
  customerName           String
  customerPhone          String?
  customerEmail          String?
  message                String    @db.Text
  budget                 Decimal?  @db.Decimal(10, 2)
  postcode               String?
  city                   String?
  state                  String?
  category               String? // Service category
  // Canonical LB pipeline status. See src/leads/canonical-status.ts.
  // Pipeline: new -> contacted -> engaged -> quoted -> booked -> scheduled -> in_progress -> completed
  // Terminals: lost, cancelled, no_show, archived
  status                 String    @default("new")
  // Set when status='lost'. Values: 'opt_out' | 'hired_someone' | 'no_response' | 'manual'
  lostReason             String?
  // When this lead becomes a re-engage candidate (e.g. lost+hired_someone -> +75d).
  reengageAt             DateTime?
  thumbtackStatus        String? // Job status from Thumbtack UI (e.g. "Hired", "Not hired")
  platformStatus         String? // Generic platform-native status (Yelp Done/Closed/Hired, etc.)
  platformStatusAt       DateTime? // When platform status was last observed
  threadId               String? // Universal conversation ID
  rawJson                String    @db.Text // Original platform payload
  syncedToCrm            Boolean   @default(false)
  // Service Flow sync fields (see plans/2026-04-17-job-sync-sf-lb.md)
  sfJobId                String? // SF jobs.id — sticky mapping
  sfJobMappedAt          DateTime?
  sfLastEventAt          DateTime? // Last accepted SF event occurred_at
  statusSource           String? // 'service_flow' | 'platform_sync' | 'manual' | 'lb_automation'
  statusUpdatedAt        DateTime? // When Lead.status last changed; used for ordering
  // Last time a customer message arrived on this lead. Provider-agnostic
  // signal read by the follow-up scheduler self-heal to stop enrollments
  // even when a provider failed to persist a Message row.
  lastCustomerActivityAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relationships
  user                    User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation            Conversation?                @relation(fields: [threadId], references: [id])
  pendingMessages         PendingAutomatedMessage[]
  pendingNotificationMsgs PendingNotificationMessage[]
  callConnectSessions     LeadCallConnect[]
  leadConversations       LeadConversation[]
  threadContexts          ThreadContext[] // Intelligence layer (multiple if lead has multiple threads)
  followUpEnrollments     FollowUpEnrollment[] // Follow-up sequences for this lead
  statusAuditLogs         LeadStatusAuditLog[]
  sfInboundEvents         SfInboundEvent[]

  @@unique([platform, externalRequestId])
  @@index([userId])
  @@index([platform])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@index([sfJobId])
  @@index([statusSource])
  @@index([lastCustomerActivityAt])
  @@index([reengageAt])
  @@map("leads")
}

// ==========================================
// Messaging & Conversations
// ==========================================

model Conversation {
  id               String    @id @default(uuid())
  userId           String
  platform         String // "thumbtack" | "yelp" | etc.
  externalThreadId String // Platform's conversation/thread ID
  customerName     String
  lastMessageAt    DateTime  @default(now())
  unreadCount      Int       @default(0)
  status           String    @default("active") // "active" | "archived" | "closed"
  metadataJson     String?   @db.Text
  // Backfill bookkeeping — populated by future recurring sync (cache plan Phase 2/3).
  // Lets the sync pick "needs backfill" deterministically without per-row Message.count
  // queries. Null = never backfilled. Otherwise: "in_progress" | "complete" | "failed".
  backfillStatus   String?
  lastBackfilledAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages            Message[]
  leads               Lead[]
  threadContext       ThreadContext? // Intelligence layer (1:1, owned by conversation-context module)
  followUpEnrollments FollowUpEnrollment[] // Follow-up sequences attached to this conversation

  @@unique([platform, externalThreadId])
  @@index([userId])
  @@index([platform])
  @@index([lastMessageAt])
  @@index([backfillStatus])
  @@map("conversations")
}

model Message {
  id                String    @id @default(uuid())
  conversationId    String
  userId            String
  platform          String // "thumbtack" | "yelp" | etc.
  externalMessageId String? // Platform's message ID
  sender            String // "pro" | "customer" | "system"
  senderType        String? // "user" | "ai" — distinguishes human vs AI-sent messages (for sender="pro")
  content           String    @db.Text
  isRead            Boolean   @default(false)
  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?
  rawJson           String?   @db.Text
  notificationLogId String? // Links outbound SMS to NotificationLog for delivery status
  createdAt         DateTime  @default(now())

  // Relationships
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, externalMessageId])
  @@index([conversationId])
  @@index([userId])
  @@index([sentAt])
  @@index([notificationLogId])
  @@map("messages")
}

// ==========================================
// Quote & Negotiation Tracking
// ==========================================

model Quote {
  id              String    @id @default(uuid())
  userId          String
  platform        String
  externalQuoteId String? // Platform's quote ID
  leadId          String? // Reference to lead if applicable
  amount          Decimal   @db.Decimal(10, 2)
  currency        String    @default("USD")
  description     String?   @db.Text
  status          String    @default("pending") // "pending" | "accepted" | "rejected" | "expired"
  validUntil      DateTime?
  rawJson         String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("quotes")
}

// ==========================================
// Message Templates & AI Prompt Templates
// type="message" — SMS/reply templates with {variables}
// type="prompt"  — AI system prompts for auto-reply
// ==========================================

model MessageTemplate {
  id         String    @id @default(uuid())
  userId     String
  name       String // Template name for identification
  content    String    @db.Text // Template content with {variables} OR AI system prompt text
  type       String    @default("message") // "message" | "prompt"
  isDefault  Boolean   @default(false)
  usageCount Int       @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relationships
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRules       AutomationRule[]   @relation("RuleMessageTemplate")
  automationPromptRules AutomationRule[]   @relation("RulePromptTemplate")
  notificationRules     NotificationRule[]

  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@map("message_templates")
}

// ==========================================
// Saved Accounts (for multi-account switching)
// ==========================================

model SavedAccount {
  id                       String   @id @default(uuid())
  userId                   String
  platform                 String // "thumbtack"
  businessId               String // Platform's business ID
  businessName             String // Display name
  emailHint                String? // Email used for this account (optional hint)
  imageUrl                 String? // Business logo URL
  webhookId                String? // Webhook subscription ID for this business
  credentialsJson          String? // Encrypted: access_token, refresh_token for THIS account
  agentPhoneOverride       String? // Per-business agent phone; when null, inherits User.businessPhone
  // Follow-up settings (per-account)
  followUpMode             String? // 'off' | 'suggest' | 'auto_send'
  aiConversationEnabled    Boolean  @default(false) // Separate toggle: auto-reply to customer messages
  followUpPreset           String? // 'conservative' | 'standard' | 'persistent'
  followUpReplyType        String? // 'template' | 'ai'
  followUpActiveHoursStart String? // e.g. "09:00"
  followUpActiveHoursEnd   String? // e.g. "21:00"
  followUpTimezone         String? // e.g. "America/New_York"
  followUpSettingsJson     String?  @db.Text // Extended follow-up settings (timing, rules, scenarios)
  // Service pricing configuration (JSON — per-account pricing table)
  servicePricingJson       String?  @db.Text
  // FAQ — per-account answers to common customer questions, injected as REFERENCE in AI prompts
  faqJson                  String?  @db.Text
  // Team — when set, org members can access this account
  organizationId           String?
  lastUsedAt               DateTime @default(now())
  createdAt                DateTime @default(now())

  // Relationships
  user                 User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?               @relation("OrgAccounts", fields: [organizationId], references: [id], onDelete: SetNull)
  automationRules      AutomationRule[]
  notificationSettings NotificationSettings?
  callConnectSettings  CallConnectSettings?
  followUpTemplates    FollowUpSequenceTemplate[]
  collectedLeads       ThumbtackLeadId[]
  settingsSnapshots    ThumbtackSettingsSnapshot[]
  healthStatuses       AccountHealthStatus[]

  @@unique([userId, platform, businessId])
  @@index([userId])
  @@index([organizationId])
  @@map("saved_accounts")
}

// ==========================================
// Webhook Event Log
// ==========================================

model WebhookEvent {
  id              String    @id @default(uuid())
  platform        String
  eventType       String // "request.created" | "message.created" | etc.
  payload         String    @db.Text
  signature       String?
  verified        Boolean   @default(false)
  processed       Boolean   @default(false)
  processingError String?   @db.Text
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?

  @@index([platform])
  @@index([eventType])
  @@index([processed])
  @@index([receivedAt])
  @@map("webhook_events")
}

// ==========================================
// Automation Rules (for auto-sending messages)
// ==========================================

model AutomationRule {
  id                  String    @id @default(uuid())
  savedAccountId      String // Per-account rules
  userId              String
  name                String // User-friendly rule name
  triggerType         String // "new_lead" | "customer_reply"
  replyTriggerMode    String? // For customer_reply: "first_only" | "every_reply"
  templateId          String? // Message template (null when useAi=true)
  promptTemplateId    String?   @map("prompt_template_id") // AI prompt template (type="prompt")
  delayMinutes        Int       @default(0) // Delay before sending (0 = immediate)
  enabled             Boolean   @default(true)
  useAi               Boolean   @default(false) // Use AI to generate reply instead of template
  replyMode           String    @default("custom") @map("reply_mode") // "custom" (template) | "price" (AI w/ locked price strategy) | "auto" (AI w/ user-selected prompt)
  aiSystemPrompt      String? // DEPRECATED — use promptTemplateId. Kept for backward compat.
  // Follow-up active hours — window when delayed follow-ups are allowed to fire
  activeHoursStart    String?   @map("active_hours_start") // e.g. "09:00"
  activeHoursEnd      String?   @map("active_hours_end") // e.g. "21:00"
  activeHoursTimezone String?   @default("America/New_York") @map("active_hours_tz")
  isFollowUp          Boolean   @default(false) @map("is_follow_up") // Marks as follow-up (vs immediate auto-reply)
  stopOnCustomerReply Boolean   @default(true) @map("stop_on_customer_reply")
  triggerCount        Int       @default(0)
  lastTriggeredAt     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relationships
  savedAccount    SavedAccount              @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        MessageTemplate?          @relation("RuleMessageTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  promptTemplate  MessageTemplate?          @relation("RulePromptTemplate", fields: [promptTemplateId], references: [id], onDelete: SetNull)
  pendingMessages PendingAutomatedMessage[]

  @@index([savedAccountId])
  @@index([userId])
  @@index([triggerType])
  @@index([enabled])
  @@map("automation_rules")
}

model PendingAutomatedMessage {
  id               String    @id @default(uuid())
  automationRuleId String
  leadId           String
  negotiationId    String // External negotiation ID (for dedup)
  scheduledFor     DateTime // When to send
  status           String    @default("pending") // "pending" | "sent" | "cancelled" | "failed"
  failureReason    String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  // Relationships
  automationRule AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([automationRuleId, negotiationId])
  @@index([status])
  @@index([scheduledFor])
  @@map("pending_automated_messages")
}

// ==========================================
// SMS Notification Settings (Sigcore Integration)
// ==========================================

model NotificationSettings {
  id                     String    @id @default(uuid())
  savedAccountId         String?   @unique // Per-account settings (optional - if null, this is user-level default)
  userId                 String? // User ID (for account-specific AND user-level settings)
  enabled                Boolean   @default(false)
  destinationPhone       String? // Company phone to send notifications to
  senderMode             String    @default("shared") // "shared" | "dedicated" | "openphone"
  sigcoreApiKey          String?   @map("callioApiKey") // Encrypted Sigcore API key
  sigcoreWorkspaceId     String?   @map("callioWorkspaceId") // Sigcore workspace ID for this tenant
  sigcoreTenantId        String?   @map("sigcore_tenant_id") // Sigcore Tenant UUID for this account
  sigcoreProvisionedAt   DateTime? @map("sigcore_provisioned_at") // When the tenant was provisioned in Sigcore
  template               String    @default("New lead: {{lead.name}}\nPhone: {{lead.phone}}\nService: {{lead.service}}\nLocation: {{lead.location}}") @db.Text
  quietHoursStart        String? // e.g., "22:00"
  quietHoursEnd          String? // e.g., "08:00"
  quietHoursTimezone     String?   @default("America/New_York")
  requirePhone           Boolean   @default(true) // Only notify if lead has phone
  customerTextingEnabled Boolean   @default(false) // Separate toggle for customer-facing SMS texting
  inboundSmsWebhookId    String? // Sigcore webhook ID for inbound SMS
  smsForwardingNumber    String? // E.164 phone to forward inbound SMS to (e.g. OpenPhone)
  callForwardingNumber   String? // E.164 phone to forward inbound calls to
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relationships
  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAccount      SavedAccount?      @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  notificationLogs  NotificationLog[]
  notificationRules NotificationRule[]

  @@index([savedAccountId])
  @@index([userId])
  @@map("notification_settings")
}

// ==========================================
// SMS Notification Rules
// ==========================================

model NotificationRule {
  id                     String    @id @default(uuid())
  notificationSettingsId String // Link to parent settings
  name                   String // User-friendly rule name (e.g., "New Lead Alert")
  triggerType            String // "new_lead" | "customer_reply"
  replyTriggerMode       String? // For customer_reply: "first_only" | "every_reply"
  fromPhone              String? // Sigcore phone number to send FROM
  toPhone                String? // Destination phone number to send TO
  sendToCustomer         Boolean   @default(false) // If true, send SMS to lead.customerPhone instead of toPhone
  template               String    @db.Text // SMS template for this specific rule (fallback if no templateId)
  templateId             String? // Optional link to MessageTemplate
  delayMinutes           Int       @default(0) // Delay before sending (0 = immediate)
  stopOnCustomerReply    Boolean   @default(true) // Cancel pending follow-ups if customer replies
  stopOnLeadClosed       Boolean   @default(true) // Cancel pending follow-ups if lead closed/won/lost
  stopOnOptOut           Boolean   @default(true) // Cancel pending follow-ups if customer sends STOP
  enabled                Boolean   @default(true)
  triggerCount           Int       @default(0)
  lastTriggeredAt        DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relationships
  notificationSettings NotificationSettings         @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  messageTemplate      MessageTemplate?             @relation(fields: [templateId], references: [id], onDelete: SetNull)
  notificationLogs     NotificationLog[]
  pendingMessages      PendingNotificationMessage[]

  @@index([notificationSettingsId])
  @@index([triggerType])
  @@index([enabled])
  @@map("notification_rules")
}

model PendingNotificationMessage {
  id                 String    @id @default(uuid())
  notificationRuleId String
  leadId             String
  savedAccountId     String // For quick lookups by account
  scheduledFor       DateTime // When to send
  status             String    @default("pending") // "pending" | "sent" | "cancelled" | "failed"
  failureReason      String?
  sentAt             DateTime?
  createdAt          DateTime  @default(now())

  // Relationships
  notificationRule NotificationRule @relation(fields: [notificationRuleId], references: [id], onDelete: Cascade)
  lead             Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([notificationRuleId, leadId])
  @@index([status])
  @@index([scheduledFor])
  @@index([savedAccountId])
  @@map("pending_notification_messages")
}

model NotificationLog {
  id                     String    @id @default(uuid())
  notificationSettingsId String
  notificationRuleId     String? // Reference to the rule that triggered this
  ruleName               String? // Cached rule name for display
  leadId                 String? // Reference to the lead that triggered this
  toPhone                String // Destination phone number
  fromPhone              String? // Sender phone number
  provider               String? // "twilio" | "openphone" | etc.
  sigcoreMessageId       String?   @map("callioMessageId") // Sigcore's message ID
  sigcoreConversationId  String?   @map("callioConversationId") // Sigcore's conversation ID
  status                 String    @default("pending") // "pending" | "queued" | "sent" | "delivered" | "failed"
  error                  String?   @db.Text
  messageBody            String    @db.Text // Rendered message content
  metadata               String?   @db.Text // JSON metadata
  createdAt              DateTime  @default(now())
  sentAt                 DateTime?
  deliveredAt            DateTime?

  // Relationships
  notificationSettings NotificationSettings @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  notificationRule     NotificationRule?    @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)

  @@index([notificationSettingsId])
  @@index([notificationRuleId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

// ==========================================
// Subscription & Billing Tracking
// ==========================================

model SubscriptionHistory {
  id            String             @id @default(uuid())
  userId        String
  tier          SubscriptionTier
  status        SubscriptionStatus
  eventType     String // "subscription.created", "subscription.updated", etc.
  stripeEventId String             @unique
  metadata      Json? // Store full Stripe event data
