  code        String? // Structured issue code: 'token_expired', 'webhook_missing', 'automation_failure'
  platform    String? // Platform context for dedup: 'thumbtack' | 'yelp'
  severity    String    @default("error") // 'error' | 'warning'
  message     String    @db.Text
  context     String?   @db.Text // JSON: accountName, leadId, negotiationId, etc.
  userId      String?
  accountId   String? // SavedAccount id
  accountName String? // Denormalized for quick display
  resolved    Boolean   @default(false)
  emailedAt   DateTime? // Last time an alert email was sent for this error
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([category, createdAt])
  @@index([resolved, createdAt])
  @@index([userId, createdAt])
  @@index([category, accountId, platform, code, resolved])
  @@map("system_error_logs")
}

// ==========================================
// Account Health Status — Source of truth for system health
