// ==========================================

model AccountHealthStatus {
  id                String    @id @default(cuid())
  userId            String
  accountId         String
  platform          String
  status            String // 'healthy' | 'warning' | 'critical'
  issueCode         String // 'token_expired' | 'webhook_missing' | 'notifications_disabled' | 'automation_failures' | 'yelp_connection'
  issueMessage      String    @db.Text
  metadata          Json?
  isActive          Boolean   @default(true)
  firstDetectedAt   DateTime  @default(now())
  lastDetectedAt    DateTime  @default(now())
  lastCheckedAt     DateTime  @default(now())
  resolvedAt        DateTime?
  lastNotifiedAt    DateTime?
  notificationCount Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

