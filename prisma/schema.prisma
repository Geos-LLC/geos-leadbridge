// ==========================================
// Conversation Context — Intelligence Layer
// Owned by conversation-context module.
// Reads from Conversation + Message; writes here.
// Designed for future extraction to Behavior IQ service.
// ==========================================

model ThreadContext {
  id             String  @id @default(cuid())
  conversationId String  @unique // 1:1 with Conversation
  leadId         String? // Denormalized for lead-level queries
  platform       String // Denormalized: "thumbtack" | "yelp"

  // Conversation stage & strategy
  stage             String  @default("new") // new, qualification, quoting, negotiation, booked, lost, closed
  customerIntent    String? // price_shopping, ready_to_book, just_browsing, urgent, unknown
  engagementLevel   String  @default("unknown") // cold, warm, hot, unknown
  activeStrategy    String? // Current strategy being used
  suggestedStrategy String? // AI-suggested next strategy

  // Rolling summary — AI-friendly, updated after messages
  summary String? @db.Text

  // Full structured state — machine-readable JSON
  stateJson String? @db.Text

  // Price tracking
  priceDiscussed Boolean @default(false)
  priceRange     String? // e.g. "$120-$180"

  // Conversation progress
  lastQuestionAsked     String? @db.Text
  missingFields         Json? // Array of field names still needed
  awaitingCustomerReply Boolean @default(false)

  // Follow-up tracking (cached from FollowUpEnrollment — derived, not source of truth)
  followUpCount      Int       @default(0)
  lastFollowUpAt     DateTime?
  lastFollowUpSentAt DateTime? // Source of truth for conversation-level send cooldown
  followUpStatus     String? // none, active, suggested, paused, completed, stopped
  activeEnrollmentId String? // FK FollowUpEnrollment (cached, nullable)
  nextFollowUpAt     DateTime? // Denormalized from enrollment.nextStepDueAt
  waitingSince       DateTime? // When business last spoke, customer hasn't replied
  followUpState      String? // Derived: no_reply_after_initial, no_reply_after_question, etc.

  // Per-sender-type timestamps
  lastCustomerMessageAt DateTime?
  lastBusinessMessageAt DateTime?
  lastAiMessageAt       DateTime?

  // Message stats (denormalized for quick reads)
  totalMessages    Int @default(0)
  customerMessages Int @default(0)
  businessMessages Int @default(0)
  aiMessages       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([platform])
  @@index([stage])
  @@index([awaitingCustomerReply])
  @@index([updatedAt])
  @@map("thread_contexts")
}

// ==========================================
// Follow-Up Engine — Sequence-based follow-ups
// Owned by follow-up-engine module.
// Reads from ThreadContext (source of truth); writes here.
// Designed for Yelp v1, extensible to Thumbtack.
// ==========================================

model FollowUpSequenceTemplate {
  id                  String   @id @default(cuid())
  userId              String
  savedAccountId      String? // Per-account scoping (same as AutomationRule, NotificationSettings)
  platform            String // "yelp" | "thumbtack" | "all" — required everywhere
  name                String // e.g. "Standard — No Reply After Initial"
  triggerState        String // "no_reply_after_initial" | "no_reply_after_question" | "no_reply_after_price" | "no_reply_after_conversion"
  mode                String   @default("suggest") // "suggest" | "auto_send"
  generationMode      String   @default("ai") // "ai" | "template"
  promptTemplateId    String? // FK MessageTemplate (AI mode prompt)
  preset              String? // "conservative" | "standard" | "persistent"
  isDefault           Boolean  @default(false)
  activeHoursStart    String?  @map("active_hours_start") // "09:00"
  activeHoursEnd      String?  @map("active_hours_end") // "21:00"
  activeHoursTimezone String?  @default("America/New_York") @map("active_hours_tz")
  stepsJson           Json // Versioned: { schemaVersion: 1, steps: [...] }
  schemaVersion       Int      @default(1) @map("schema_version")
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAccount SavedAccount?        @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  enrollments  FollowUpEnrollment[]

  @@index([savedAccountId, platform, triggerState])
  @@index([userId, platform, triggerState])
  @@index([isDefault, platform, triggerState])
  @@map("follow_up_sequence_templates")
}

model FollowUpEnrollment {
  id                 String    @id @default(cuid())
  sequenceTemplateId String
  conversationId     String // FK Conversation
  leadId             String? // FK Lead (nullable)
  platform           String // "yelp" | "thumbtack"
  status             String    @default("active") // "active" | "paused" | "completed" | "stopped"
  stoppedReason      String? // "customer_replied" | "manual" | "switched" | "thread_closed"
  currentStepIndex   Int       @default(0) // 0-based pointer into stepsJson
  nextStepDueAt      DateTime? // CRITICAL: scheduler queries this
  mode               String    @default("suggest") // can override template default
  startedAt          DateTime  @default(now())
  lastExecutedAt     DateTime?
  completedAt        DateTime?
  // Atomic scheduler claim (lease-based). processingUntil is the lease
  // expiration; processingToken is the worker's random token. A lease
  // is "live" while processingUntil > now(). Workers claim a row by
  // conditionally updating these fields.
  processingUntil    DateTime?
  processingToken    String?
  // Engagement-aware follow-up (see plans/2026-04-17-job-sync-sf-lb.md §7.4)
  followUpMode       String    @default("short_term") // "short_term" | "long_term"
  modeChangedAt      DateTime?
  modeReason         String? // e.g. 'platform_not_hired_engaged' | 'ghost_returned'
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sequenceTemplate FollowUpSequenceTemplate     @relation(fields: [sequenceTemplateId], references: [id], onDelete: Cascade)
  conversation     Conversation                 @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead             Lead?                        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  stepExecutions   FollowUpStepExecution[]
  auditLog         FollowUpEnrollmentAuditLog[]

  @@index([status, nextStepDueAt]) // Scheduler query: find due active enrollments
  @@index([conversationId, status]) // Active enrollment lookup per thread
  @@index([leadId])
  @@index([followUpMode, status])
  // NOTE: Partial unique index enforced via raw SQL migration
  //   20260417120000_followup_duplicate_fix:
  //     CREATE UNIQUE INDEX ... ON follow_up_enrollments (conversation_id) WHERE status = 'active';
  @@map("follow_up_enrollments")
}

/// Audit log for state transitions on FollowUpEnrollment.
/// Phase 1 Task 4 — historical state-change visibility + sourceEventId-based
/// idempotency for retry-prone callers (webhook handlers, scheduler).
///
/// One row per actual transition. The `updateMany` filter on prior status
/// ensures the row is only created when a real state change happened (count
/// === 1). The sourceEventId column lets retry-prone callers dedup at the
/// audit-row level: if a row already exists with the same sourceEventId,
/// the entire transition no-ops.
model FollowUpEnrollmentAuditLog {
  id            String   @id @default(cuid())
  enrollmentId  String
  oldStatus     String // e.g. "active"
  newStatus     String // e.g. "stopped" | "paused" | "active" | "completed"
  reason        String? // free-form: "customer_replied" | "manual" | "lead_status_lost" | "lead_status_booked" | etc.
  sourceEventId String? // dedup key — null when caller didn't provide
  actorType     String? // "system" | "manual" | "webhook" | "cron" | "scheduler"
  actorId       String? // operator userId, webhook event id, or cron run id
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  enrollment FollowUpEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, createdAt(sort: Desc)])
  @@index([sourceEventId])
  @@map("follow_up_enrollment_audit_log")
}

model FollowUpStepExecution {
  id               String    @id @default(cuid())
  enrollmentId     String
  stepIndex        Int // Which step in stepsJson
  objective        String // "quick_check_in" | "value_add" | "soft_nudge" | "re_engagement" | "last_chance" | ...
  status           String    @default("scheduled") // "scheduled" | "suggested" | "approved" | "sent" | "skipped" | "cancelled" | "failed" | "expired"
  scheduledAt      DateTime // When it was supposed to fire
  executedAt       DateTime? // When it actually fired
  generatedMessage String?   @db.Text // AI/template output (what was generated)
  finalMessage     String?   @db.Text // What was actually sent (may differ if user edited)
  messageId        String? // FK to Message table (if sent to platform)
  strategyUsed     String? // Active AI strategy at generation time
  metadataJson     String?   @db.Text // Delivery status, error info, context snapshot
  createdAt        DateTime  @default(now())

  enrollment FollowUpEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, stepIndex])
  @@index([status])
  @@map("follow_up_step_executions")
}

// ==========================================
// Team / Organization
// ==========================================

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       OrgMembership[]
  invitations   OrgInvitation[]
  savedAccounts SavedAccount[]  @relation("OrgAccounts")

  @@map("organizations")
}

model OrgMembership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("org_memberships")
}

model OrgInvitation {
  id             String    @id @default(uuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  token          String    @unique @default(uuid())
  invitedBy      String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([token])
  @@index([email])
  @@map("org_invitations")
}

// ==========================================
// CRM Webhook Subscriptions (outbound events)
// ==========================================

model CrmWebhookSubscription {
  id          String    @id @default(uuid())
  userId      String
  name        String // e.g. "Service Flow CRM"
  webhookUrl  String
  secret      String // HMAC-SHA256 signing secret
  events      String[] // e.g. ["lead.created", "message.received", "message.sent", "lead.status_changed"]
  isActive    Boolean   @default(true)
  direction   String    @default("outbound") // "outbound" | "inbound"
  lastEventAt DateTime? // For inbound: last received event time
  metadata    Json? // Extra context (e.g. source app, version)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, direction, webhookUrl])
  @@index([userId, isActive])
  @@index([direction, isActive])
  @@map("crm_webhook_subscriptions")
}

// ==========================================
// Service Flow sync: inbound events + audit log
// See plans/2026-04-17-job-sync-sf-lb.md
// ==========================================

model SfInboundEvent {
  id               String   @id @default(uuid())
  eventId          String   @unique // payload.event_id — idempotency key
  userId           String? // Resolved LB user (null when lookup failed)
  leadId           String? // Resolved LB lead (null when deferred)
  sfJobId          String?
  sfSubscriptionId String?
  eventType        String // "job.status_changed" | future types
  occurredAt       DateTime // payload.occurred_at
  receivedAt       DateTime @default(now())
  status           String // 'applied'|'noop'|'deferred'|'stale'|'unmapped_status'|'unauthorized'|'dry_run'
  result           String?
  // Populated when ingest threw, validation failed, signature mismatched,
  // or status was unmappable. Surfaces in /v1/integrations/health failed count.
  processingError  String?
  payloadJson      Json

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status, receivedAt])
  @@index([sfJobId])
  @@map("sf_inbound_events")
}

// LB → external CRM outbound delivery audit. One row per (subscription, event_id)
// attempt cluster — attempts increments on each retry, state moves
// pending → sent | failed. event_id is the same id sent in the payload, so it
// links to the receiver's inbound event row + LB's LeadStatusAuditLog.sourceEventId.
model CrmWebhookDelivery {
  id             String    @id @default(uuid())
  subscriptionId String
  eventType      String
  eventId        String
  attempts       Int       @default(0)
  state          String // 'pending' | 'sent' | 'failed'
  lastStatusCode Int?
  lastError      String?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([eventId])
  @@map("crm_webhook_deliveries")
}

model LeadStatusAuditLog {
  id            String   @id @default(uuid())
  leadId        String
  // Activity discriminator. Defaults to status_changed; future activity types
  // (note_added, message_sent, etc.) can reuse the table without schema churn.
  activityType  String   @default("status_changed")
  oldStatus     String?
  newStatus     String
  source        String // 'service_flow'|'platform_sync'|'manual'|'lb_automation'
  sourceEventId String? // e.g. SfInboundEvent.eventId, Message.id
  actorType     String? // 'account_owner'|'team_member'|'system'|'operator'
  actorId       String?
  actorName     String?
  // Reason for the transition. For lost: 'opt_out'|'hired_someone'|'no_response'|'manual'.
  // For other transitions: short freeform note (e.g. 'customer_replied').
  reason        String?
  // Future-proof escape hatch for non-status activity payloads.
  metadata      Json?
  conflict      Boolean  @default(false) // true for discrepancy-audit rows
  conflictNote  String?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, occurredAt])
  @@index([leadId, activityType, occurredAt])
  @@index([conflict])
  @@map("lead_status_audit_log")
}

// ==========================================
// Phase 2 — Data Access Log
//
// Security-relevant access events. Captures: admin/support reads of customer
// data, impersonated reads/writes, sensitive tenant writes, exports, and
// account/security actions. Does NOT log every normal tenant read.
//
// Strict allowed-fields policy: never store message bodies, full customer PII,
// tokens, secrets, webhook payloads, AI prompts/responses. The AuditService
// applies sanitization to free-text fields (`reason`) and rejects
// any payload-shaped input. No relations to User — audit rows must outlive
// user deletion as a forensic record.
//
// Default retention: 180 days (enforced by a future cleanup cron, not this PR).
// ==========================================

model DataAccessLog {
  id           String   @id @default(uuid())
  actorUserId  String // Who performed the action (impersonator's id when impersonation is in play)
  actorRole    String // 'USER' | 'ADMIN' | 'SYSTEM'
  tenantId     String // Whose data was touched
  action       String // 'read' | 'list' | 'create' | 'update' | 'delete' | 'export'
  resourceType String? // 'Lead' | 'Conversation' | 'Message' | 'NotificationSettings' | 'CallConnectSettings' | 'MessageTemplate' | 'CrmWebhookSubscription' | 'Platform' | etc.
  resourceId   String?
  accessType   String // 'tenant_self' | 'impersonation_read' | 'impersonation_write' | 'admin_read' | 'support_read' | 'export'
  reason       String? // Optional support-grant reason; sanitized (phone/email masked) before persist
  route        String? // HTTP path or domain action label
  method       String? // HTTP method
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([tenantId, createdAt])
  @@index([resourceType, resourceId])
  @@index([accessType, createdAt])
  @@map("data_access_logs")
}

// ==========================================
// Phase 3 — Support Grant
//
// Time-bound, scope-limited authorization for ADMIN reads of customer-data
// endpoints. The mere `ADMIN` role is no longer sufficient; the admin must
// also hold an unexpired SupportGrant whose `scopes` include the required
// permission and whose `tenantId` matches the targeted tenant (or is the
// platform-wide sentinel `__platform__`).
//
// No relations to User: the row must outlive admin/tenant deletion as a
// forensic record. Pairs with `data_access_logs` rows where
// accessType = 'support_read' for full who/what/why audit chain.
//
// Default duration on create: 60 minutes. Hard cap: 7 days (enforced at
// service layer, not schema). Indexed on (adminUserId, expiresAt) and
// (tenantId, expiresAt) so guard checks are O(log n) lookups.
// ==========================================

model SupportGrant {
  id          String   @id @default(cuid())
  adminUserId String // Admin user issuing/holding the grant
  tenantId    String // Target tenant; '__platform__' for cross-tenant bulk endpoints
  scopes      String[] // e.g. ['user:read', 'notifications:read']
  reason      String   @db.Text // Audit context — propagated to DataAccessLog.reason
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([adminUserId, expiresAt])
  @@index([tenantId, expiresAt])
  @@map("support_grants")
}
