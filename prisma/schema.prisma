// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// Enums for Billing & Admin
// ==========================================

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionTier {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

// ==========================================
// Core User Management
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?  // For user authentication in your app
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Role & Subscription fields
  role                  UserRole            @default(USER)
  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique
  subscriptionTier      SubscriptionTier?
  subscriptionStatus    SubscriptionStatus?
  subscriptionPeriodEnd DateTime?
  hasOwnNumber          Boolean             @default(false)

  // Relationships
  platforms           Platform[]
  leads               Lead[]
  conversations       Conversation[]
  messages            Message[]
  savedAccounts       SavedAccount[]
  messageTemplates    MessageTemplate[]
  automationRules     AutomationRule[]
  subscriptionHistory SubscriptionHistory[]
  adminLogs           AdminLog[]

  @@map("users")
}

// ==========================================
// Multi-Platform Integration
// ==========================================

model Platform {
  id                 String   @id @default(uuid())
  userId             String
  platformName       String   // "thumbtack" | "yelp" | "angi" | "bark"
  connected          Boolean  @default(true)
  externalUserId     String?  // Platform's user ID
  externalBusinessId String?  // Platform's business ID (for webhook matching)
  credentialsJson    String   // Encrypted: access_token, refresh_token, api_key, etc.
  webhookSecret      String?  // Encrypted webhook verification secret
  webhookId          String?  // Platform's webhook subscription ID
  lastSyncAt         DateTime?
  metadataJson       String?  // Additional platform-specific data
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platformName])
  @@index([userId])
  @@index([platformName])
  @@index([externalBusinessId])
  @@map("platforms")
}

// ==========================================
// Normalized Lead Management
// ==========================================

model Lead {
  id                String   @id @default(uuid())
  userId            String
  platform          String   // "thumbtack" | "yelp" | etc.
  businessId        String?  // Platform's business ID (for multi-account filtering)
  externalRequestId String   // Platform's unique lead/request ID
  customerName      String
  customerPhone     String?
  customerEmail     String?
  message           String   @db.Text
  budget            Decimal? @db.Decimal(10, 2)
  postcode          String?
  city              String?
  state             String?
  category          String?  // Service category
  status            String   @default("new") // "new" | "contacted" | "quoted" | "booked" | "lost"
  threadId          String?  // Universal conversation ID
  rawJson           String   @db.Text // Original platform payload
  syncedToCrm       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation    Conversation?             @relation(fields: [threadId], references: [id])
  pendingMessages PendingAutomatedMessage[]

  @@unique([platform, externalRequestId])
  @@index([userId])
  @@index([platform])
  @@index([businessId])
  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// ==========================================
// Messaging & Conversations
// ==========================================

model Conversation {
  id              String   @id @default(uuid())
  userId          String
  platform        String   // "thumbtack" | "yelp" | etc.
  externalThreadId String  // Platform's conversation/thread ID
  customerName    String
  lastMessageAt   DateTime @default(now())
  unreadCount     Int      @default(0)
  status          String   @default("active") // "active" | "archived" | "closed"
  metadataJson    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
  leads    Lead[]

  @@unique([platform, externalThreadId])
  @@index([userId])
  @@index([platform])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  conversationId  String
  userId          String
  platform        String   // "thumbtack" | "yelp" | etc.
  externalMessageId String? // Platform's message ID
  sender          String   // "pro" | "customer" | "system"
  content         String   @db.Text
  isRead          Boolean  @default(false)
  sentAt          DateTime @default(now())
  deliveredAt     DateTime?
  rawJson         String?  @db.Text
  createdAt       DateTime @default(now())

  // Relationships
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, externalMessageId])
  @@index([conversationId])
  @@index([userId])
  @@index([sentAt])
  @@map("messages")
}

// ==========================================
// Quote & Negotiation Tracking
// ==========================================

model Quote {
  id              String   @id @default(uuid())
  userId          String
  platform        String
  externalQuoteId String?  // Platform's quote ID
  leadId          String?  // Reference to lead if applicable
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  description     String?  @db.Text
  status          String   @default("pending") // "pending" | "accepted" | "rejected" | "expired"
  validUntil      DateTime?
  rawJson         String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([status])
  @@map("quotes")
}

// ==========================================
// Message Templates (for bulk follow-up messages)
// ==========================================

model MessageTemplate {
  id          String    @id @default(uuid())
  userId      String
  name        String    // Template name for identification
  content     String    @db.Text // Template content with {variables}
  isDefault   Boolean   @default(false)
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRules AutomationRule[]

  @@index([userId])
  @@map("message_templates")
}

// ==========================================
// Saved Accounts (for multi-account switching)
// ==========================================

model SavedAccount {
  id              String   @id @default(uuid())
  userId          String
  platform        String   // "thumbtack"
  businessId      String   // Platform's business ID
  businessName    String   // Display name
  emailHint       String?  // Email used for this account (optional hint)
  imageUrl        String?  // Business logo URL
  webhookId       String?  // Webhook subscription ID for this business
  credentialsJson String?  // Encrypted: access_token, refresh_token for THIS account
  lastUsedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  // Relationships
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  automationRules      AutomationRule[]
  notificationSettings NotificationSettings?

  @@unique([userId, platform, businessId])
  @@index([userId])
  @@map("saved_accounts")
}

// ==========================================
// Webhook Event Log
// ==========================================

model WebhookEvent {
  id           String   @id @default(uuid())
  platform     String
  eventType    String   // "request.created" | "message.created" | etc.
  payload      String   @db.Text
  signature    String?
  verified     Boolean  @default(false)
  processed    Boolean  @default(false)
  processingError String? @db.Text
  receivedAt   DateTime @default(now())
  processedAt  DateTime?

  @@index([platform])
  @@index([eventType])
  @@index([processed])
  @@index([receivedAt])
  @@map("webhook_events")
}

// ==========================================
// Automation Rules (for auto-sending messages)
// ==========================================

model AutomationRule {
  id               String    @id @default(uuid())
  savedAccountId   String    // Per-account rules
  userId           String
  name             String    // User-friendly rule name
  triggerType      String    // "new_lead" | "customer_reply"
  replyTriggerMode String?   // For customer_reply: "first_only" | "every_reply"
  templateId       String    // Reference to MessageTemplate
  delayMinutes     Int       @default(0) // Delay before sending (0 = immediate)
  enabled          Boolean   @default(true)
  triggerCount     Int       @default(0)
  lastTriggeredAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  savedAccount    SavedAccount              @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        MessageTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  pendingMessages PendingAutomatedMessage[]

  @@index([savedAccountId])
  @@index([userId])
  @@index([triggerType])
  @@index([enabled])
  @@map("automation_rules")
}

model PendingAutomatedMessage {
  id               String    @id @default(uuid())
  automationRuleId String
  leadId           String
  negotiationId    String    // External negotiation ID (for dedup)
  scheduledFor     DateTime  // When to send
  status           String    @default("pending") // "pending" | "sent" | "cancelled" | "failed"
  failureReason    String?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  // Relationships
  automationRule AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([automationRuleId, negotiationId])
  @@index([status])
  @@index([scheduledFor])
  @@map("pending_automated_messages")
}

// ==========================================
// SMS Notification Settings (Callio Integration)
// ==========================================

model NotificationSettings {
  id                String   @id @default(uuid())
  savedAccountId    String   @unique // Per-account settings
  enabled           Boolean  @default(false)
  destinationPhone  String?  // Company phone to send notifications to
  senderMode        String   @default("shared") // "shared" | "dedicated" | "openphone"
  callioApiKey      String?  // Encrypted Callio API key
  callioFromPhone   String?  // Selected phone number from Callio to send from
  callioWorkspaceId String?  // Callio workspace ID for this tenant
  callioWebhookId   String?  // Callio webhook ID for delivery status updates
  template          String   @db.Text @default("New lead: {{lead.name}}\nPhone: {{lead.phone}}\nService: {{lead.service}}\nLocation: {{lead.location}}")
  quietHoursStart   String?  // e.g., "22:00"
  quietHoursEnd     String?  // e.g., "08:00"
  quietHoursTimezone String? @default("America/New_York")
  requirePhone      Boolean  @default(true) // Only notify if lead has phone
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships
  savedAccount      SavedAccount        @relation(fields: [savedAccountId], references: [id], onDelete: Cascade)
  notificationLogs  NotificationLog[]
  notificationRules NotificationRule[]

  @@index([savedAccountId])
  @@map("notification_settings")
}

// ==========================================
// SMS Notification Rules
// ==========================================

model NotificationRule {
  id                     String   @id @default(uuid())
  notificationSettingsId String   // Link to parent settings
  name                   String   // User-friendly rule name (e.g., "New Lead Alert")
  triggerType            String   // "new_lead" | "customer_reply"
  replyTriggerMode       String?  // For customer_reply: "first_only" | "every_reply"
  fromPhone              String?  // Callio phone number to send FROM
  toPhone                String?  // Destination phone number to send TO
  template               String   @db.Text // SMS template for this specific rule
  enabled                Boolean  @default(true)
  triggerCount           Int      @default(0)
  lastTriggeredAt        DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relationships
  notificationSettings NotificationSettings @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  notificationLogs     NotificationLog[]

  @@index([notificationSettingsId])
  @@index([triggerType])
  @@index([enabled])
  @@map("notification_rules")
}

model NotificationLog {
  id                    String    @id @default(uuid())
  notificationSettingsId String
  notificationRuleId    String?   // Reference to the rule that triggered this
  ruleName              String?   // Cached rule name for display
  leadId                String?   // Reference to the lead that triggered this
  toPhone               String    // Destination phone number
  fromPhone             String?   // Sender phone number
  provider              String?   // "twilio" | "openphone" | etc.
  callioMessageId       String?   // Callio's message ID
  callioConversationId  String?   // Callio's conversation ID
  status                String    @default("pending") // "pending" | "queued" | "sent" | "delivered" | "failed"
  error                 String?   @db.Text
  messageBody           String    @db.Text // Rendered message content
  metadata              String?   @db.Text // JSON metadata
  createdAt             DateTime  @default(now())
  sentAt                DateTime?
  deliveredAt           DateTime?

  // Relationships
  notificationSettings NotificationSettings @relation(fields: [notificationSettingsId], references: [id], onDelete: Cascade)
  notificationRule     NotificationRule?    @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)

  @@index([notificationSettingsId])
  @@index([notificationRuleId])
  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}

// ==========================================
// Subscription & Billing Tracking
// ==========================================

model SubscriptionHistory {
  id            String             @id @default(uuid())
  userId        String
  tier          SubscriptionTier
  status        SubscriptionStatus
  eventType     String // "subscription.created", "subscription.updated", etc.
  stripeEventId String             @unique
  metadata      Json? // Store full Stripe event data
  createdAt     DateTime           @default(now())

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("subscription_history")
}

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String
  action       String // "UPDATE_USER_SUBSCRIPTION", "DELETE_USER", etc.
  targetUserId String?
  details      Json?
  createdAt    DateTime @default(now())

  // Relationships
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_logs")
}
